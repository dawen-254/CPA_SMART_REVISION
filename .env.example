# Django Settings
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For Development (SQLite) - Leave these commented
# DB_ENGINE=django.db.backends.sqlite3

# For Production (PostgreSQL) - Uncomment and configure
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cpa_revision_db
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# AI API Keys (Choose one or both)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Default AI Provider (openai, anthropic, or gemini)
AI_PROVIDER=openai

# M-Pesa Daraja API Configuration (Production)
MPESA_ENVIRONMENT=sandbox  # sandbox or production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379  # Your shortcode
MPESA_PASSKEY=your-passkey
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your-security-credential
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback/

# Stripe Configuration (Optional - International payments)
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=CPA Smart Revision <noreply@cpasmartrevision.co.ke>

# Redis Cache (Optional - for production)
REDIS_URL=redis://localhost:6379/0

# Security Settings (Production)
SECURE_SSL_REDIRECT=False  # Set to True in production with HTTPS
SESSION_COOKIE_SECURE=False  # Set to True in production
CSRF_COOKIE_SECURE=False  # Set to True in production

# Static Files (Production)
AWS_ACCESS_KEY_ID=your-aws-key  # If using S3
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Application Settings
SITE_NAME=CPA Smart Revision
SITE_URL=http://localhost:8000
ADMIN_EMAIL=admin@cpasmartrevision.co.ke

# AI Usage Limits (per month)
FREE_PLAN_AI_LIMIT=5
BASIC_PLAN_AI_LIMIT=50
PREMIUM_PLAN_AI_LIMIT=999999  # Unlimited

# Subscription Prices (KES)
BASIC_MONTHLY_PRICE=500
PREMIUM_MONTHLY_PRICE=1200
PREMIUM_ANNUAL_PRICE=8000

# Monitoring (Production)
SENTRY_DSN=your-sentry-dsn

# Feature Flags
ENABLE_AI_TUTOR=True
ENABLE_MOCK_EXAMS=True
ENABLE_STUDY_PLANNER=True
ENABLE_SUBSCRIPTIONS=True
